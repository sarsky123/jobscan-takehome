# Do not commit .env. Copy this file to .env and set values as needed.

# Required for ingestion (embedding calls). Optional override for backend.
OPENAI_API_KEY=

# Backend (optional; defaults point to storage/ under repo root)
# BACKEND_FAISS_INDEX_PATH=storage/vectors/faiss_index.bin
# BACKEND_JOB_IDS_PATH=storage/vectors/job_ids.json
# BACKEND_DOCUMENTS_PATH=storage/documents/jobs.json
# BACKEND_OPENAI_API_KEY=

# Ingestion paths (optional; defaults: storage/feed, storage/vectors/*, storage/documents/jobs.json)
# JOBS_INPUT_DIR=storage/feed
# FAISS_INDEX_PATH=storage/vectors/faiss_index.bin
# JOB_IDS_PATH=storage/vectors/job_ids.json
# DOCUMENTS_PATH=storage/documents/jobs.json
